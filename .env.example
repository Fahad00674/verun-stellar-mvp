## Verun Stellar MVP — environment

# Required: signer secret key (S...). The public address is derived from this.
STELLAR_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Public address of the signer. Optional — derived from STELLAR_SECRET if missing.
# If set, the app verifies it matches the secret on /api/config-check.
STELLAR_PUBLIC=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stellar Horizon endpoint (Testnet by default)
HORIZON_URL=https://horizon-testnet.stellar.org

# Network passphrase. Testnet = "Test SDF Network ; September 2015"
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Friendbot endpoint for auto-funding the testnet account on first call.
# Leave default unless you know what you're doing.
FRIENDBOT_URL=https://friendbot.stellar.org

# Local express port (only for `npm run api`, not Vercel)
PORT=3010
